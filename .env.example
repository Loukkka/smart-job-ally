# --- Stripe (paiement premium réel) ---
# Renseignez ces clés pour activer le vrai tunnel de paiement Stripe.
# Sans elles, l'app bascule automatiquement en mode démo (paiement simulé).
# Clé secrète : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# --- Site ---
# URL publique du site (utilisée pour les redirections Stripe). Optionnel en local.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
